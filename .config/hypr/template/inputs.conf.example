# Input
input {
    kb_layout = us
    kb_variant = #colemak  
    kb_model =
    kb_options =
    kb_rules =

    follow_mouse = 1

    sensitivity = 0.45 # -acceleration = false1.0 - 1.0, 0 means no modification.
    accel_profile = flat

    touchpad {
        natural_scroll = true
    }
}


# Example per-device config
# See https://wiki.hyprland.org/Configuring/Keywords/#per-device-input-configs for more
device {
    name = epic-mouse-v1
    sensitivity = -0.5
}
